<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        EI_EXPOSE_REP / EI_EXPOSE_REP2: Lombok @Data/@Getter generates
        getters that return mutable internal state (e.g. List, Date).
        These are expected in DTOs and entities managed by JPA.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
